# STAGE 1: Build and Compile
FROM mcr.microsoft.com/dotnet/sdk:11.0-preview AS build-env
WORKDIR /src

# Copy project files and restore dependencies to optimize layer caching
COPY *.csproj ./
RUN dotnet restore --no-cache

# Copy the remaining source code and compile the application
COPY . ./
RUN dotnet publish -c Release -o /app/publish

# STAGE 2: Production Runtime
FROM mcr.microsoft.com/dotnet/aspnet:11.0-preview
WORKDIR /app

# Copy the compiled binaries from the build stage
COPY --from=build-env /app/publish .

# Expose the default port (Starting with .NET 8, it defaults to 8080)
EXPOSE 8080

# Configure the container to execute your application
ENTRYPOINT ["dotnet", "server.dll"]
