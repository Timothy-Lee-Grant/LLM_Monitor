# ---------------------------------------------------------------------------
# .env.example (plan 003 Step 4) — copy values into .env (gitignored).
# NEVER commit real values. If a key ever lands in a tracked file, ROTATE it
# in the provider portal — git history is never rewritten in this repo.
# ---------------------------------------------------------------------------

# Mode & provider ------------------------------------------------------------
# LLM_MODE: mock (default; no external calls, $0) | live
# LLM_PROVIDER (live only): azure (default) | openai_compat | ollama
#LLM_MODE=live
#LLM_PROVIDER=azure

# Cost guard: hard cap on model OUTPUT tokens per call (paid providers).
#LLM_MAX_TOKENS=1024

# Tool-loop guard: max graph steps per request (~3 tool round-trips at 8).
#TOOL_RECURSION_LIMIT=8

# Azure OpenAI (LLM_PROVIDER=azure) ------------------------------------------
# From portal.azure.com -> your Azure OpenAI resource:
#   Endpoint + key:   Resource -> Keys and Endpoint
#   API version:      current GA data-plane version from the Azure OpenAI docs
#   Deployments:      the *deployment names YOU chose* in Azure AI Foundry
#                     (Azure addresses deployments, not model names)
#AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
#AZURE_OPENAI_API_KEY=
#AZURE_OPENAI_API_VERSION=
#AZURE_OPENAI_CHAT_DEPLOYMENT=
#AZURE_OPENAI_EMBED_DEPLOYMENT=

# OpenAI-compatible endpoint (LLM_PROVIDER=openai_compat; plan 003 Step 5b) --
# Any OpenAI-protocol provider: Groq, Gemini-compat, OpenRouter, ...
# Chat only — no embeddings on this path (free tiers don't serve them).
#OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
#OPENAI_COMPAT_API_KEY=
#OPENAI_COMPAT_MODEL=

# Existing knobs (documented here for completeness; defaults in compose) -----
#LLM_MODEL=llama3.1:8b
#OBSERVABILITY_ENABLED=true
#POSTGRES_USER=admin
#POSTGRES_PASSWORD=secret_pass
#POSTGRES_DB=vectordb
