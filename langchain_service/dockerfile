# Runtime for the langchain_service.
# python:3.11-slim: matches CI's interpreter (the old 3.9 base predated
# current langchain releases, which have dropped 3.9 support).
#
# (Old TODO answered: uvicorn is an ASGI server — for async frameworks like
# FastAPI/Starlette. Flask is WSGI (synchronous), so its production server
# is gunicorn. uvicorn would not run this app.)
FROM python:3.11-slim

WORKDIR /service

# Dependencies first, source second: docker caches layers top-down, so code
# edits don't re-trigger the (slow) pip install layer.
COPY requirements.txt requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

# Ingestion-then-gunicorn sequence lives in the entrypoint (see entrypoint.sh).
CMD ["bash", "entrypoint.sh"]
